APP_PORT=8088
APP_BASE_URL=http://localhost:8088
FRONTEND_ORIGIN=http://127.0.0.1:8080,http://localhost:8080,null
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=12345678
DEFAULT_ADMIN_DISPLAY_NAME=系统管理员

POSTGRES_DSN=postgres://postgres:postgres@localhost:55432/alliance_vault?sslmode=disable
JWT_SECRET=alliance-vault-dev-secret
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_HOURS=168

# Keep MINIO_* names for compatibility; local deployment uses RustFS.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=rustfsadmin
MINIO_SECRET_KEY=rustfsadmin
MINIO_BUCKET=alliance-vault
MINIO_USE_SSL=false

UPLOAD_URL_EXPIRE_SECONDS=900
DOWNLOAD_URL_EXPIRE_SECONDS=600
MAX_UPLOAD_SIZE_MB=20
